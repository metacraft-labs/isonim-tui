# Build / test outputs.
test-logs/
nim-cache/
bench-results/

# direnv local state.
.direnv/

# Compiled test binaries (Justfile + per-test compile output).
tests/test_*
!tests/test_*.nim
!tests/test_*.cfg

# Compiled example binaries (each examples/<name>/<name> matching its dir name).
examples/calculator/calculator
examples/code_browser/code_browser
examples/datatable_demo/datatable_demo
examples/dictionary/dictionary
examples/log_viewer/log_viewer
examples/markdown_viewer/markdown_viewer
examples/system_monitor/system_monitor
examples/task_app_demo/task_app_demo

# M29 real-terminal scenario binaries (one per scenario file).
tests/real_terminal/test_real_*
!tests/real_terminal/test_real_*.nim
# M29 per-widget test app binaries (each apps/<name> stripped of extension).
tests/real_terminal/apps/*
!tests/real_terminal/apps/*.nim
!tests/real_terminal/apps/*.nims

# Nim caches.
*.dSYM
*.exe
*.pdb
src/isonim_tui/syntax/highlighter
src/isonim_tui/syntax/treesitter_ffi
tests/snapshots/_report.html
